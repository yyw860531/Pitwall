# Anthropic
ANTHROPIC_API_KEY=your_key_here

# Claude model for reasoning/language agents (coaching_writer, data_gatherer, synthetic_lap)
CLAUDE_MODEL=claude-sonnet-4-6

# Claude model for calculation-only agents (corner_analysis, braking_efficiency, balance_diagnosis)
# Haiku is faster and cheaper for structured JSON output tasks.
CLAUDE_MODEL_FAST=claude-haiku-4-5

# Path to your Assetto Corsa installation root.
# Required for synthetic reference laps (Tools 5 & 6).
# Leave blank to skip the Synthetic Lap Agent.
# Example (Windows): C:\Program Files (x86)\Steam\steamapps\common\assettocorsa
AC_ROOT=

# PitWall paths (defaults shown — only set if you want to override)
PITWALL_DB_PATH=db/pitwall.db
PITWALL_DATA_DIR=data/sessions

# Path to your Telemetrick export folder (the root that contains car/track subfolders).
# If set, run_session.py can discover sessions automatically without specifying a file path.
# Example (Windows): C:\Users\YourName\OneDrive\Documents\Assetto Corsa\apps\telemetrick\exported\YourDriver
TELEMETRY_EXPORT_DIR=

# Lap validity filter (milliseconds). Laps outside this range are marked invalid
# when the 'Lap Invalidated' channel is not present in the .ld file.
PITWALL_VALID_LAP_MIN_MS=30000
PITWALL_VALID_LAP_MAX_MS=120000
